#!/bin/bash

# Skill Hub 同步工具
# 用法: ./skill-sync "提交信息"
# 示例: ./skill-sync "feat: 添加 Flutter 架构规范"

set -e

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# 检查是否有未提交的更改
if [ -z "$(git status --porcelain)" ]; then
    echo -e "${YELLOW}没有需要提交的更改${NC}"
    exit 0
fi

# 获取提交信息
COMMIT_MSG="${1:-feat: 更新 Skill}"

# 添加所有更改
echo -e "${GREEN}📦 添加更改...${NC}"
git add -A

# 提交
echo -e "${GREEN}💾 提交更改...${NC}"
git commit -m "$COMMIT_MSG"

# 推送到远程
echo -e "${GREEN}🚀 推送到远程...${NC}"
git push

echo -e "${GREEN}✅ 完成！Skill 已同步到远程仓库${NC}"
