#!/bin/bash

# Skill Manager - Skill 安装工具
# 功能：列出、安装 Skills 到项目或全局

set -e

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 配置
REPO_URL="https://github.com/PipeDog/PipeDog-SkillHub.git"
REPO_NAME="PipeDog-SkillHub"
GLOBAL_DIR="${HOME}/.skill-manager/skills"

# 获取脚本所在目录
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILLS_DIR="${SCRIPT_DIR}/skills"

# 打印帮助
usage() {
    echo -e "${BLUE}Skill Manager${NC} - Skill 安装工具"
    echo ""
    echo "用法:"
    echo "  skill-manager <command> [options]"
    echo ""
    echo "命令:"
    echo "  list                  列出所有可用的 Skills"
    echo "  install <skill-name> [目标目录]  安装 Skill 到当前项目"
    echo "  install-global <skill-name>  安装 Skill 到全局"
    echo "  search <keyword>      搜索 Skill"
    echo "  help                  显示帮助"
    echo ""
    echo "示例:"
    echo "  skill-manager list"
    echo "  skill-manager install flutter-architecture"
    echo "  skill-manager install flutter-architecture cursor   # 安装到 .cursor/skills/（Cursor 编辑器）"
    echo "  skill-manager install-global flutter-architecture"
    echo "  skill-manager search flutter"
}

# 列出所有 Skills
cmd_list() {
    echo -e "${BLUE}可用的 Skills:${NC}"
    echo ""
    
    if [ ! -d "${SKILLS_DIR}" ]; then
        echo -e "${RED}错误: skills 目录不存在${NC}"
        exit 1
    fi
    
    local count=0
    for dir in "${SKILLS_DIR}"/*/; do
        if [ -d "${dir}" ]; then
            local name=$(basename "${dir}")
            local skill_file="${dir}SKILL.md"
            
            if [ -f "${skill_file}" ]; then
                # 提取描述（第一行 # 之后的内容）
                local description=$(sed -n 's/^# //p' "${skill_file}" | head -1)
                echo -e "  ${GREEN}${name}${NC}"
                [ -n "${description}" ] && echo -e "      ${description}"
                echo ""
            else
                echo -e "  ${GREEN}${name}${NC}"
                echo -e "      (无描述)"
                echo ""
            fi
            ((count++))
        fi
    done
    
    echo "共 ${count} 个 Skills"
}

# 搜索 Skill
cmd_search() {
    local keyword="$1"
    
    if [ -z "${keyword}" ]; then
        echo -e "${RED}错误: 请提供搜索关键词${NC}"
        exit 1
    fi
    
    echo -e "${BLUE}搜索: ${keyword}${NC}"
    echo ""
    
    local found=0
    for dir in "${SKILLS_DIR}"/*/; do
        if [ -d "${dir}" ]; then
            local name=$(basename "${dir}")
            
            # 搜索文件名和内容
            if echo "${name}" | grep -qi "${keyword}"; then
                echo -e "  ${GREEN}${name}${NC} (名称匹配)"
                ((found++))
            elif [ -f "${dir}SKILL.md" ]; then
                if grep -qi "${keyword}" "${dir}SKILL.md"; then
                    echo -e "  ${GREEN}${name}${NC} (内容匹配)"
                    ((found++))
                fi
            fi
        fi
    done
    
    echo ""
    echo "找到 ${found} 个结果"
}

# 安装 Skill 到当前项目
cmd_install() {
    local skill_name="$1"
    local target_dir_raw="${2:-skills}"
    
    if [ -z "${skill_name}" ]; then
        echo -e "${RED}错误: 请指定要安装的 Skill 名称${NC}"
        echo "使用: skill-manager install <skill-name> [目标目录]"
        echo "      目标目录可使用 cursor 快捷安装到 .cursor/skills/（Cursor 编辑器）"
        exit 1
    fi
    
    # 兼容 Cursor 编辑器：cursor 或 .cursor/skills 解析为 .cursor/skills/
    local target_dir
    if [ "${target_dir_raw}" = "cursor" ] || [ "${target_dir_raw}" = ".cursor/skills" ]; then
        target_dir=".cursor/skills"
    else
        target_dir="${target_dir_raw}"
    fi
    
    local source_dir="${SKILLS_DIR}/${skill_name}"
    
    if [ ! -d "${source_dir}" ]; then
        echo -e "${RED}错误: Skill '${skill_name}' 不存在${NC}"
        echo ""
        echo "可用的 Skills:"
        cmd_list
        exit 1
    fi
    
    # 确保目标目录存在
    mkdir -p "${target_dir}"
    
    # 复制文件
    echo -e "${GREEN}安装 ${skill_name} 到 ${target_dir}...${NC}"
    cp -r "${source_dir}" "${target_dir}/"
    
    echo -e "${GREEN}✅ 安装完成！${NC}"
    echo "已安装到: ${target_dir}/${skill_name}"
}

# 安装 Skill 到全局
cmd_install_global() {
    local skill_name="$1"
    
    if [ -z "${skill_name}" ]; then
        echo -e "${RED}错误: 请指定要安装的 Skill 名称${NC}"
        exit 1
    fi
    
    local source_dir="${SKILLS_DIR}/${skill_name}"
    
    if [ ! -d "${source_dir}" ]; then
        echo -e "${RED}错误: Skill '${skill_name}' 不存在${NC}"
        echo ""
        echo "可用的 Skills:"
        cmd_list
        exit 1
    fi
    
    # 创建全局目录
    mkdir -p "${GLOBAL_DIR}"
    
    # 复制文件
    echo -e "${GREEN}全局安装 ${skill_name}...${NC}"
    cp -r "${source_dir}" "${GLOBAL_DIR}/"
    
    echo -e "${GREEN}✅ 全局安装完成！${NC}"
    echo "已安装到: ${GLOBAL_DIR}/${skill_name}"
}

# 主命令处理
COMMAND="${1:-help}"

case "${COMMAND}" in
    list)
        cmd_list
        ;;
    search)
        cmd_search "$2"
        ;;
    install)
        cmd_install "$2" "$3"
        ;;
    install-global)
        cmd_install_global "$2"
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        echo -e "${RED}未知命令: ${COMMAND}${NC}"
        echo ""
        usage
        exit 1
        ;;
esac
